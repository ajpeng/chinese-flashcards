generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Article {
  id        Int      @id @default(autoincrement())
  title     String
  hskLevel  Int
  content   String
  words     Word[]
}

model Word {
  id         Int      @id @default(autoincrement())
  simplified String
  pinyin     String
  english    String
  hskLevel   Int
  articleId  Int
  article    Article  @relation(fields: [articleId], references: [id])
}
