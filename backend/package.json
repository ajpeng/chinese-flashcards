{
  "name": "backend",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "node dist/bin/www.js",
    "dev": "ts-node-dev --respawn --transpile-only src/bin/www.ts",
    "build": "prisma generate && tsc",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:seed": "prisma db seed",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "node dist/prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^7.2.0",
    "cookie-parser": "~1.4.4",
    "cors": "^2.8.5",
    "debug": "~2.6.9",
    "express": "~4.16.1",
    "http-errors": "~1.6.3",
    "jade": "~1.11.0",
    "morgan": "~1.9.1",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "dotenv": "^17.2.3",
    "prisma": "^7.2.0",
    "typescript": "^5.7.0",
    "ts-node-dev": "^2.0.0",
    "@types/node": "^22.10.1",
    "@types/express": "^4.17.21",
    "@types/cookie-parser": "^1.4.3",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "@types/debug": "^4.1.12",
    "@types/pg": "^8.11.10",
    "@types/jade": "^0.0.33"
  }
}
